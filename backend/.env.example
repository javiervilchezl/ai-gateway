APP_NAME=ai-gateway-backend
APP_ENV=development
LOG_LEVEL=INFO
PROVIDER=groq
OPENAI_API_KEY=PON-AQUI-TU-API-KEY-SEGURA-PARA-OPENAI-XXX-XX-XXXX-XX
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=PON-AQUI-TU-API-KEY-SEGURA-PARA-GROQ-XXX-XX-XXXX-XX
GROQ_MODEL=llama-3.1-8b-instant
PDF_SERVICE_URL=http://localhost:8001
CLASSIFIER_SERVICE_URL=http://localhost:8002
INTENT_SERVICE_URL=http://localhost:8003
# Optional for server-to-server clients. Leave empty for browser JWT-only flow.
GATEWAY_API_KEY=
GATEWAY_API_KEY_HEADER=X-API-Key
INTERNAL_SERVICE_API_KEY=PON-AQUI-TU-API-KEY-SEGURA-PARA-SERVICIOS-INTERNOS-XX
INTERNAL_SERVICE_API_KEY_HEADER=X-Service-API-Key
JWT_SECRET_KEY=PON-AQUI-UN-SECRET-LARGO-ALEATORIO-PARA-JWT-XXX-XX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
AUTH_REQUIRE_JWT=true
# DB-backed auth — admin user seeded automatically on first start
DATABASE_URL=mysql+pymysql://gateway_user:TU-MYSQL-PASSWORD@localhost:3306/gateway_db
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=PON-AQUI-UNA-CONTRASENA-FUERTE-PARA-LOGIN-XXX-XX
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_REQUESTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
CORS_ALLOW_ORIGINS=http://localhost:5173
TRUSTED_CLIENT_IPS=
HELICONE_API_KEY=
LANGFUSE_PUBLIC_KEY=PON-AQUI-TU-API-KEY-SEGURA-PARA-LANGFUSE-PUBLIC-XXX-XX
LANGFUSE_SECRET_KEY=PON-AQUI-TU-API-KEY-SEGURA-PARA-LANGFUSE-SECRET-XXX-XX
LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_OPENLIT=false
